# Скопируй в Railway → Variables (не в файл .env — Railway использует свою панель переменных)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here
DB_PATH=/data/app.db

# Dodo Payments
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_ENVIRONMENT=test_mode
DODO_WEBHOOK_KEY=your_dodo_webhook_signing_key_here
DODO_PRODUCT_WEEKLY=pdt_xxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_MONTHLY=pdt_xxxxxxxxxxxxxxxxxxxxx
DODO_PRODUCT_YEARLY=pdt_xxxxxxxxxxxxxxxxxxxxx
